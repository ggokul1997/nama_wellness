# =============================================================
# NAMA WELLNESS — ENVIRONMENT VARIABLES
# =============================================================
# Copy this file to .env at the root AND to:
#   apps/api/.env
#   apps/web/.env.local
# Then fill in the values below.
# =============================================================

# =============================================================
# DATABASE (PostgreSQL via Docker)
# =============================================================
# For local dev, use the Docker Compose postgres service.
# Host = localhost, Port = 5432 (mapped from container).
DATABASE_URL="postgresql://nama_user:nama_password@localhost:5432/nama_wellness?schema=public"

# =============================================================
# REDIS
# =============================================================
# For local dev, use the Docker Compose redis service.
REDIS_URL="redis://localhost:6379"

# =============================================================
# JWT SECRETS
# =============================================================
# Generate strong secrets:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NEVER share these or commit them.
JWT_ACCESS_SECRET="REPLACE_WITH_64_CHAR_HEX_SECRET"
JWT_REFRESH_SECRET="REPLACE_WITH_ANOTHER_64_CHAR_HEX_SECRET"

# Token expiry (use ms/s/m/h/d notation)
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# =============================================================
# EMAIL — ETHEREAL (Fake SMTP for development)
# =============================================================
# Ethereal is a free fake SMTP service by Nodemailer.
# HOW IT WORKS:
#   1. Leave these blank in development — the API will auto-create
#      a new Ethereal account on first startup and log the credentials.
#   2. Copy the printed ETHEREAL_USER and ETHEREAL_PASS into this file
#      to reuse the same test inbox across restarts.
#   3. View sent emails at: https://ethereal.email/messages
#      (log in with the printed credentials)
# FOR PRODUCTION: Replace with real SMTP (e.g., AWS SES, SendGrid).
ETHEREAL_USER=""
ETHEREAL_PASS=""

# Email "From" address shown to recipients
EMAIL_FROM="Nama Wellness <noreply@namawellness.com>"

# =============================================================
# APP
# =============================================================
NODE_ENV="development"
PORT="4000"
API_BASE_URL="http://localhost:4000"
WEB_BASE_URL="http://localhost:3000"

# Allowed CORS origins (comma-separated for multiple)
CORS_ORIGINS="http://localhost:3000"

# =============================================================
# AWS S3 — LocalStack (local dev only)
# =============================================================
# LocalStack emulates S3 locally on port 4566.
# For production: replace with real AWS credentials.
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="test"
AWS_SECRET_ACCESS_KEY="test"
AWS_S3_BUCKET_NAME="nama-wellness-uploads"
# LocalStack endpoint — remove this for production AWS
AWS_ENDPOINT_URL="http://localhost:4566"

# =============================================================
# NEXT.JS FRONTEND (apps/web/.env.local)
# =============================================================
# The Next.js app needs to know the API URL.
# NEXT_PUBLIC_ prefix exposes to the browser.
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_APP_NAME="Nama Wellness"

# =============================================================
# FUTURE — Add these in later sprints (leave blank for now)
# =============================================================

# Razorpay (Sprint D)
# RAZORPAY_KEY_ID=""
# RAZORPAY_KEY_SECRET=""
# RAZORPAY_WEBHOOK_SECRET=""

# Stripe (Sprint D)
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""

# Google Calendar / Meet (Sprint C)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=""

# OpenAI (Sprint G)
# OPENAI_API_KEY=""
