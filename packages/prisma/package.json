{
  "name": "@nama/prisma",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Prisma ORM schema, client, migrations, and seeds",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "prisma generate --schema=./prisma/schema.prisma && tsc",
    "db:generate": "prisma generate --schema=./prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "db:migrate:prod": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "db:seed": "tsx prisma/seeds/index.ts",
    "db:studio": "prisma studio --schema=./prisma/schema.prisma",
    "db:reset": "prisma migrate reset --schema=./prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "argon2": "^0.43.0",
    "prisma": "^6.10.1"
  },
  "devDependencies": {
    "@nama/config": "workspace:*",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
